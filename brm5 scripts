INPUT_CONN = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not STATE.running then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        STATE.rightMouseDown = true
        return
    end

    if gameProcessed then
        return
    end

    if input.UserInputType ~= Enum.UserInputType.Keyboard then
        return
    end

    if not STATE.authenticated then
        if input.KeyCode == Enum.KeyCode.Return then
            processLogin()
        end
        return
    end

    if STATE.espBindMode then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            CONFIG.ESP_TOGGLE_KEY = input.KeyCode
            STATE.espBindMode = false
            UI.espBindButton.Text = "Press key to toggle ESP"
            refreshUi()
        end
        return
    end

    if STATE.bindMode then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            CONFIG.TOGGLE_MENU_KEY = input.KeyCode
            STATE.bindMode = false
            UI.bindButton.Text = "Change Menu Key"
            refreshUi()
        end
        return
    end

    if input.KeyCode == CONFIG.TOGGLE_MENU_KEY then
        setMenuVisible(not UI.panel.Visible, false)
        return
    end

    if input.KeyCode == CONFIG.ESP_TOGGLE_KEY then
        CONFIG.ESP_ACTIVO = not CONFIG.ESP_ACTIVO
        if not CONFIG.ESP_ACTIVO then
            clearEspOnTargets()
        end
        pushNotification("HabibiScripts", CONFIG.ESP_ACTIVO and "ESP enabled" or "ESP disabled")
        refreshUi()
    end
end)

RENDER_CONN = RunService.RenderStepped:Connect(function()
    if not STATE.running then
        return
    end

    if STATE.activeSlider and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local entry = UI_STATE.sliders[STATE.activeSlider]
        if entry then
            local alpha = (UserInputService:GetMouseLocation().X - entry.bar.AbsolutePosition.X) / entry.bar.AbsoluteSize.X
            entry.setter(alpha)
            updateSliderVisual(STATE.activeSlider)
        end
    else
        STATE.activeSlider = nil
    end

    if STATE.dragging and STATE.dragTarget and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local delta = UserInputService:GetMouseLocation() - STATE.dragStart
        local proposedPosition = UDim2.new(
            0,
            STATE.dragOrigin.X.Offset + delta.X,
            0,
            STATE.dragOrigin.Y.Offset + delta.Y
        )

        STATE.dragTarget.Position = clampFramePosition(STATE.dragTarget, proposedPosition)
        if STATE.dragTarget == UI.panel then
            syncAuraPosition(UI.panelAura, UI.panel, 36)
        elseif STATE.dragTarget == UI.loginFrame then
            syncAuraPosition(UI.loginAura, UI.loginFrame, 30)
        end
    else
        STATE.dragging = false
        STATE.dragTarget = nil
    end

    local cam = getCurrentCamera()
    if cam then
        local currentPitch = math.asin(math.clamp(cam.CFrame.LookVector.Y, -1, 1))

        if CONFIG.ANTI_RECOIL and STATE.authenticated and not UI.panel.Visible and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local lastPitch = STATE.lastCameraPitch
            if lastPitch then
                local pitchDelta = currentPitch - lastPitch
                if pitchDelta > 0 and pitchDelta < 0.09 then
                    local correction = pitchDelta * math.clamp(CONFIG.ANTI_RECOIL_STRENGTH, 0, 1)
                    cam.CFrame = cam.CFrame * CFrame.Angles(-correction, 0, 0)
                    currentPitch = math.asin(math.clamp(cam.CFrame.LookVector.Y, -1, 1))
                end
            end
        end

        STATE.lastCameraPitch = currentPitch
    else
        STATE.lastCameraPitch = nil
    end

    updateFovCirclePosition()
    UI.fovCircle.Visible = CONFIG.SHOW_FOV and STATE.authenticated
end)

RunService:BindToRenderStep(AIMBOT_BIND_NAME, Enum.RenderPriority.Camera.Value + 2, function()
    if not STATE.running or not STATE.authenticated then
        return
    end

    local cam = getCurrentCamera()
    if not cam then
        return
    end

    if CONFIG.AIMBOT_ACTIVO then
        if UI.panel.Visible or not STATE.rightMouseDown then
            STATE.lockedTarget = nil
            return
        end

        if tick() - STATE.lastScan >= 0.05 then
            STATE.lastScan = tick()
            refreshTargets()
        end

        local target = getBestTarget()
        STATE.lockedTarget = target

        if target then
            aimAt(target)
        end
    else
        STATE.lockedTarget = nil
    end

end)

