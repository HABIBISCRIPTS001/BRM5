local function ensureModelHighlight(model, data)
    local highlight = model:FindFirstChild("HabibiHighlight")
        or model:FindFirstChildOfClass("Highlight")

    if highlight and highlight.Parent ~= model then
        highlight = nil
    end

    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "HabibiHighlight"
        highlight.Parent = model
        highlight.Adornee = model
    end

    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 1
    highlight.OutlineTransparency = 0
    data.highlight = highlight
    return highlight
end

