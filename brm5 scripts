local function saveSettings()
    if not writefile then
        return false, "Executor sin writefile"
    end

    local payload = {
        AIMBOT_ACTIVO = CONFIG.AIMBOT_ACTIVO,
        ESP_ACTIVO = CONFIG.ESP_ACTIVO,
        ESP_NAME = CONFIG.ESP_NAME,
        ESP_DISTANCE = CONFIG.ESP_DISTANCE,
        ESP_HIGHLIGHT = CONFIG.ESP_HIGHLIGHT,
        ESP_TOGGLE_KEY = CONFIG.ESP_TOGGLE_KEY.Name,
        SHOW_FOV = CONFIG.SHOW_FOV,
        TEAM_CHECK = CONFIG.TEAM_CHECK,
        VISIBILITY_CHECK = CONFIG.VISIBILITY_CHECK,
        WORLD_TIME_ENABLED = CONFIG.WORLD_TIME_ENABLED,
        ANTI_RECOIL = CONFIG.ANTI_RECOIL,
        ANTI_RECOIL_STRENGTH = CONFIG.ANTI_RECOIL_STRENGTH,
        TARGET_PART = CONFIG.TARGET_PART,
        WORLD_TIME = CONFIG.WORLD_TIME,
        FOV = CONFIG.FOV,
        SMOOTH = CONFIG.SMOOTH,
        ESP_RENDER_DISTANCE = CONFIG.ESP_RENDER_DISTANCE,
        ENEMY_COLOR_R = CONFIG.ENEMY_COLOR_R,
        ENEMY_COLOR_G = CONFIG.ENEMY_COLOR_G,
        ENEMY_COLOR_B = CONFIG.ENEMY_COLOR_B,
        TOGGLE_MENU_KEY = CONFIG.TOGGLE_MENU_KEY.Name,
    }

    local ok, result = pcall(function()
        writefile(SETTINGS_FILE, HttpService:JSONEncode(payload))
    end)

    if not ok then
        return false, tostring(result)
    end

    return true, "Settings guardadas"
end

local function loadSettings()
    if not readfile or not isfile or not isfile(SETTINGS_FILE) then
        return false, "No existe archivo de settings"
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)

    if not ok or type(data) ~= "table" then
        return false, "Archivo de settings invalido"
    end

    for key, value in pairs(data) do
        if CONFIG[key] ~= nil then
            CONFIG[key] = value
        end
    end

    if type(CONFIG.TOGGLE_MENU_KEY) == "string" then
        CONFIG.TOGGLE_MENU_KEY = Enum.KeyCode[CONFIG.TOGGLE_MENU_KEY] or DEFAULT_CONFIG.TOGGLE_MENU_KEY
    end

    if type(CONFIG.ESP_TOGGLE_KEY) == "string" then
        CONFIG.ESP_TOGGLE_KEY = Enum.KeyCode[CONFIG.ESP_TOGGLE_KEY] or DEFAULT_CONFIG.ESP_TOGGLE_KEY
    end

    return true, "Settings cargadas"
end

local function resetSettings()
    for key, value in pairs(DEFAULT_CONFIG) do
        CONFIG[key] = value
    end
end

