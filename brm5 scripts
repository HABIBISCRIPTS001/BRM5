local function syncAuraPosition(aura, frame, padding)
    if not aura or not frame then
        return
    end

    aura.Position = UDim2.new(
        frame.Position.X.Scale,
        frame.Position.X.Offset - padding,
        frame.Position.Y.Scale,
        frame.Position.Y.Offset - padding
    )
end

local function getViewportSize()
    local cam = getCurrentCamera()
    if cam then
        return cam.ViewportSize
    end
    return Vector2.new(1920, 1080)
end

local function clampFramePosition(frame, position)
    local viewportSize = getViewportSize()
    local width = frame.AbsoluteSize.X > 0 and frame.AbsoluteSize.X or frame.Size.X.Offset
    local height = frame.AbsoluteSize.Y > 0 and frame.AbsoluteSize.Y or frame.Size.Y.Offset
    local minOffset = 12
    local maxX = math.max(minOffset, viewportSize.X - width - 12)
    local maxY = math.max(minOffset, viewportSize.Y - height - 12)

    return UDim2.new(
        0,
        math.clamp(position.X.Offset, minOffset, maxX),
        0,
        math.clamp(position.Y.Offset, minOffset, maxY)
    )
end

local function startDragging(frame, input)
    STATE.dragging = true
    STATE.dragTarget = frame
    STATE.dragStart = input.Position
    STATE.dragOrigin = UDim2.new(0, frame.Position.X.Offset, 0, frame.Position.Y.Offset)
end

local function bindDrag(handle, frame)
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            startDragging(frame, input)
        end
    end)
end

local function updateToggleVisual(id)
    local entry = UI_STATE.toggles[id]
    if not entry then
        return
    end

    local enabled = CONFIG[id]
    local backgroundColor = enabled and ELECTRIC_PRIMARY or Color3.fromRGB(48, 48, 58)
    local knobPosition = enabled and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
    local labelColor = enabled and Color3.fromRGB(255, 255, 255) or ELECTRIC_MUTED

    if entry.lastEnabled == nil then
        entry.button.BackgroundColor3 = backgroundColor
        entry.knob.Position = knobPosition
        entry.stateLabel.TextColor3 = labelColor
    elseif entry.lastEnabled ~= enabled then
        TweenService:Create(entry.button, TOGGLE_TWEEN_INFO, {
            BackgroundColor3 = backgroundColor,
        }):Play()
        TweenService:Create(entry.knob, TOGGLE_TWEEN_INFO, {
            Position = knobPosition,
        }):Play()
        TweenService:Create(entry.stateLabel, TOGGLE_TWEEN_INFO, {
            TextColor3 = labelColor,
        }):Play()
    end

    entry.stateLabel.Text = enabled and "ON" or "OFF"
    entry.lastEnabled = enabled
end

local function updateSliderVisual(id)
    local entry = UI_STATE.sliders[id]
    if not entry then
        return
    end

    local rawValue = CONFIG[id]
    local alpha = math.clamp((rawValue - entry.min) / (entry.max - entry.min), 0, 1)
    entry.fill.Size = UDim2.new(alpha, 0, 1, 0)
    entry.knob.Position = UDim2.new(alpha, 0, 0.5, 0)
    entry.label.Text = entry.formatter(rawValue)

    if id == "FOV" then
        UI.fovCircle.Size = UDim2.new(0, CONFIG.FOV * 2, 0, CONFIG.FOV * 2)
    end
end

local function updateFovCirclePosition()
    local cam = getCurrentCamera()
    if cam then
        UI.fovCircle.Position = UDim2.fromOffset(
            math.floor(cam.ViewportSize.X * 0.5),
            math.floor(cam.ViewportSize.Y * 0.5)
        )
    else
        UI.fovCircle.Position = UDim2.fromScale(0.5, 0.5)
    end
end

local function tweenInstance(instance, info, properties)
