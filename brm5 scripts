local function getCharacter(model)
    if typeof(model) == "Instance" and model:IsA("BasePart") then
        return model.Parent
    end
    return model
end

local function getPlayerFromCharacter(model)
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character == model then
            return player
        end
    end
    return nil
end

local function sameTeam(model)
    local targetPlayer = getPlayerFromCharacter(model)
    if not targetPlayer then
        return false
    end

    if LocalPlayer.Team ~= nil and targetPlayer.Team ~= nil then
        return LocalPlayer.Team == targetPlayer.Team
    end

    if LocalPlayer.TeamColor ~= nil and targetPlayer.TeamColor ~= nil then
        return LocalPlayer.TeamColor == targetPlayer.TeamColor
    end

    return false
end

local function getTargetPart(model)
    if not model then
        return nil
    end

    local function findPart(name)
        local direct = model:FindFirstChild(name)
        if direct and direct:IsA("BasePart") then
            return direct
        end

        local recursive = model:FindFirstChild(name, true)
        if recursive and recursive:IsA("BasePart") then
            return recursive
        end

        return nil
    end

    if CONFIG.TARGET_PART == "Head" then
        return findPart("Head")
            or findPart("UpperTorso")
            or findPart("HumanoidRootPart")
            or findPart("Torso")
    end

    if CONFIG.TARGET_PART == "Chest" then
        return findPart("UpperTorso")
            or findPart("Torso")
            or findPart("HumanoidRootPart")
            or findPart("Head")
    end

    return findPart("HumanoidRootPart")
        or findPart("UpperTorso")
        or findPart("Torso")
        or findPart("Head")
        or model.PrimaryPart
end

local function hasCombatRig(model)
    if not model or not model:IsA("Model") then
        return false
    end

    if getPlayerFromCharacter(model) then
        return true
    end

    if model.Name == "Male" then
        return getTargetPart(model) ~= nil
    end

    if model:FindFirstChildOfClass("Humanoid") then
        return getTargetPart(model) ~= nil
    end

    if model:FindFirstChildOfClass("AnimationController") and getTargetPart(model) then
        return true
    end

    local healthValue = model:FindFirstChild("Health") or model:FindFirstChild("Health", true)
    if healthValue and healthValue:IsA("NumberValue") and getTargetPart(model) then
        return true
    end

    return false
end

local function formatStudDistance(distance)
    if distance < 100 then
        return string.format("%.1f studs", distance)
    end

    return string.format("%d studs", math.floor(distance + 0.5))
end

local function getModelPhase(model)
    local source = model and model:GetFullName() or "habibi"
    local sum = 0
    for index = 1, #source do
        sum = (sum + string.byte(source, index) * index) % 997
    end
    return sum / 997
end

local function getElectricPulse(model)
    local phase = getModelPhase(model) * math.pi * 2
    local t = tick() * 3.6
    local wave = (math.sin(t + phase) + 1) * 0.5
    local flicker = (math.sin((t * 2.2) + (phase * 1.7)) + 1) * 0.5
    return {
        glowTransparency = 0.92 - (wave * 0.12),
        slashTransparency = 0.72 - (flicker * 0.28),
        edgeTransparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.48 - (wave * 0.14)),
            NumberSequenceKeypoint.new(0.55, 0.04 + (flicker * 0.08)),
            NumberSequenceKeypoint.new(1, 0.48 - (wave * 0.14)),
        }),
        chipStrokeTransparency = 0.3 - (wave * 0.18),
        cardStrokeTransparency = 0.12 - (wave * 0.06),
    }
end

local function getBillboardMetrics(distance)
    local alpha = math.clamp((distance - 20) / 180, 0, 1)
    local easedAlpha = alpha ^ 0.82
    local scale = 1 - (easedAlpha * 0.46)

    return {
        width = math.max(136, math.floor((252 * scale) + 0.5)),
        height = math.max(34, math.floor((64 * scale) + 0.5)),
        nameTextSize = math.max(11, math.floor((15 * scale) + 0.5)),
        distanceTextSize = math.max(9, math.floor((12 * scale) + 0.5)),
        studsOffset = -4.45 - (easedAlpha * 0.9),
    }
end

local function getTargetDisplayText(model)
    local player = getPlayerFromCharacter(model)
    if not player then
        return model.Name
    end

    if player.DisplayName and player.DisplayName ~= player.Name then
        return string.format("%s (@%s)", player.DisplayName, player.Name)
    end

    return player.Name
end

local function getAliveState(model)
    if not model or not model:IsA("Model") then
        return false
    end

    if model.Name == "Male" and getTargetPart(model) then
        local downedValue = model:FindFirstChild("Downed", true)
        if downedValue and downedValue:IsA("BoolValue") then
            return not downedValue.Value
        end

        return true
    end

    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if humanoid then
        return humanoid.Health > 0
    end

    local healthValue = model:FindFirstChild("Health") or model:FindFirstChild("Health", true)
    if healthValue and healthValue:IsA("NumberValue") then
        return healthValue.Value > 0
    end

    local downedValue = model:FindFirstChild("Downed") or model:FindFirstChild("Downed", true)
    if downedValue and downedValue:IsA("BoolValue") and downedValue.Value then
        return false
    end

    local animationController = model:FindFirstChildOfClass("AnimationController")
    local root = getTargetPart(model)
    return animationController ~= nil and root ~= nil
end

local function isTargetCandidate(model)
    if not model or not model:IsA("Model") then
        return false
    end

    if model == LocalPlayer.Character then
        return false
    end

    local root = getTargetPart(model)
    if not root then
        return false
    end

    return hasCombatRig(model)
end

local function isValidTarget(model)
    if not model or not model:IsA("Model") then return false end
    if model == LocalPlayer.Character then return false end

    if not isTargetCandidate(model) then
        return false
    end

    if not getAliveState(model) then
        return false
    end

    if CONFIG.TEAM_CHECK and sameTeam(model) then
        return false
    end

    return true
end

local function isVisiblePosition(position, targetModel)
    local cam = getCurrentCamera()
    if not cam then
        return false
    end

    local origin = cam.CFrame.Position
    local direction = position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character, targetModel}
    params.IgnoreWater = true

    local hit = workspace:Raycast(origin, direction, params)
    return hit == nil
end

local function getScreenDistance(position3D)
    local cam = getCurrentCamera()
    if not cam then
        return math.huge, false
    end

    local screenPos, onScreen = cam:WorldToViewportPoint(position3D)
    if not onScreen then
        return math.huge, false
    end

    local center = cam.ViewportSize / 2
    local delta = Vector2.new(screenPos.X, screenPos.Y) - center
    return delta.Magnitude, true
end

local function isInsideFov(position3D)
    local distance, onScreen = getScreenDistance(position3D)
    return onScreen and distance <= CONFIG.FOV
end

local function refreshNpcTargets()
    local seen = {}
    local updated = {}

    for _, instance in ipairs(workspace:GetDescendants()) do
        if instance:IsA("Model")
            and not seen[instance]
            and instance ~= LocalPlayer.Character
            and getPlayerFromCharacter(instance) == nil
            and (instance.Name == "Male" or isTargetCandidate(instance))
            and isValidTarget(instance)
        then
            seen[instance] = true
        end
    end

    for model in pairs(seen) do
        table.insert(updated, model)
    end

    NPC_TARGETS = updated
end

local function refreshTargets()
    local updated = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and isValidTarget(player.Character) then
            table.insert(updated, player.Character)
        end
    end

    if tick() - STATE.lastNpcScan >= NPC_SCAN_INTERVAL then
        STATE.lastNpcScan = tick()
        refreshNpcTargets()
    end

    for _, model in ipairs(NPC_TARGETS) do
        if isValidTarget(model) then
            table.insert(updated, model)
        end
    end

    TARGETS = updated
end

local function getVisibilityCached(model, position)
    local cached = VISIBILITY_CACHE[model]
    local now = tick()

    if cached and (now - cached.lastCheck) <= VISIBILITY_CACHE_INTERVAL then
        return cached.visible
    end

    local visible = isVisiblePosition(position, model)
    VISIBILITY_CACHE[model] = {
        visible = visible,
        lastCheck = now,
    }
    return visible
end

local function getBestTarget()
    local bestPart = nil
    local bestScreenDistance = math.huge

    for _, model in ipairs(TARGETS) do
        if isValidTarget(model) then
            local part = getTargetPart(model)
            if part then
                local visible = true
                if CONFIG.VISIBILITY_CHECK then
                    visible = getVisibilityCached(model, part.Position)
                end

                if not visible then
                    continue
                end

                local screenDistance, onScreen = getScreenDistance(part.Position)
                if onScreen and screenDistance <= CONFIG.FOV and screenDistance < bestScreenDistance then
                    bestScreenDistance = screenDistance
                    bestPart = part
                end
            end
        end
    end

    return bestPart
end

local function targetLockValid(part)
    if not part or not part.Parent then
        return false
    end

    local model = getCharacter(part)
    if not isValidTarget(model) then
        return false
    end

    if not isInsideFov(part.Position) then
        return false
    end

    if CONFIG.VISIBILITY_CHECK and not getVisibilityCached(model, part.Position) then
        return false
    end

    return true
end

local function aimAt(part)
    local cam = getCurrentCamera()
    if not cam or not part then
        return
    end

    local screenPoint, onScreen = cam:WorldToViewportPoint(part.Position)
    if not onScreen then
        return
    end

    local effectiveSmooth = math.clamp((CONFIG.SMOOTH ^ 0.55) * 1.9, 0.14, 2.2)
    local center = cam.ViewportSize / 2
    local delta = Vector2.new(screenPoint.X - center.X, screenPoint.Y - center.Y) * effectiveSmooth

    local moveX = math.floor(delta.X + (delta.X >= 0 and 0.5 or -0.5))
    local moveY = math.floor(delta.Y + (delta.Y >= 0 and 0.5 or -0.5))

    if moveX == 0 and math.abs(delta.X) >= 0.35 then
        moveX = delta.X > 0 and 1 or -1
    end

    if moveY == 0 and math.abs(delta.Y) >= 0.35 then
        moveY = delta.Y > 0 and 1 or -1
    end

    if math.abs(moveX) < 1 and math.abs(moveY) < 1 then
        return
    end

    if mousemoverel and not STATE.mouseMoveFailed then
        local ok = pcall(mousemoverel, moveX, moveY)
        if ok then
            return
        end

        STATE.mouseMoveFailed = true
    end

    local targetLook = CFrame.lookAt(cam.CFrame.Position, part.Position)
    cam.CFrame = cam.CFrame:Lerp(targetLook, math.clamp(effectiveSmooth * 0.85, 0.16, 1))
end

