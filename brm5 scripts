end

local function updateChoiceVisual(id, currentValue)
    local buttons = UI_STATE.choiceRows[id]
    if not buttons then
        return
    end

    for _, button in ipairs(buttons) do
        local active = button.Text == currentValue
        local backgroundColor = active and ELECTRIC_PRIMARY or Color3.fromRGB(52, 53, 64)
        local textColor = active and Color3.fromRGB(255, 255, 255) or ELECTRIC_MUTED
        local lastActive = button:GetAttribute("HabibiLastActive")

        if lastActive == nil then
            button.BackgroundColor3 = backgroundColor
            button.TextColor3 = textColor
        elseif lastActive ~= active then
            tweenInstance(button, CHOICE_TWEEN_INFO, {
                BackgroundColor3 = backgroundColor,
                TextColor3 = textColor,
            })
        end

        button:SetAttribute("HabibiLastActive", active)
    end
end

