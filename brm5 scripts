while STATE.running do
    task.wait(0.18)

    if not STATE.authenticated then
        continue
    end

    if tick() - STATE.lastWorldApply >= WORLD_APPLY_INTERVAL then
        STATE.lastWorldApply = tick()
        applyWorldTime()
    end

    if tick() - STATE.lastScan >= SCAN_INTERVAL then
        STATE.lastScan = tick()
        refreshTargets()
    end

    if CONFIG.ESP_ACTIVO then
        for _, model in ipairs(TARGETS) do
            if isValidTarget(model) then
                local root = getTargetPart(model)
                local data = ESP_CACHE[model]

                if not data then
                    data = {}
                    ESP_CACHE[model] = data
                end

                if root then
                    local cam = getCurrentCamera()
                    if cam then
                        local distance = (root.Position - cam.CFrame.Position).Magnitude
                        local targetVisible = getVisibilityCached(model, root.Position)
                        local targetColor = getEspColor(model, targetVisible)
                        local highlight = ensureModelHighlight(model, data)
                        if distance > CONFIG.ESP_RENDER_DISTANCE then
                            highlight.Enabled = false
                            if data.billboard then
                                data.billboard.Enabled = false
                            end
                            continue
                        end

                        if data.lastColor ~= targetColor then
                            highlight.OutlineColor = targetColor
                            data.lastColor = targetColor
                        end
                        highlight.Enabled = CONFIG.ESP_HIGHLIGHT

                        local billboard = ensureDistanceBillboard(root, data)
                        billboard.Enabled = CONFIG.ESP_DISTANCE
                        billboard.MaxDistance = CONFIG.ESP_RENDER_DISTANCE

                        local billboardMetrics = getBillboardMetrics(distance)
                        billboard.Size = UDim2.new(0, billboardMetrics.width, 0, billboardMetrics.height)
                        billboard.StudsOffset = Vector3.new(0, billboardMetrics.studsOffset, 0)

                        local card = billboard and billboard:FindFirstChild("Card")
                        if card then
                            local holder = card:FindFirstChild("Holder")
                            local nameLabel = holder and holder:FindFirstChild("NameLabel")
                            local distanceLabel = holder and holder:FindFirstChild("DistanceLabel")
                            local accent = card:FindFirstChild("Accent")
                            local cardStroke = card:FindFirstChild("CardStroke")
                            local glow = billboard:FindFirstChild("Glow")
                            local topEdge = card:FindFirstChild("TopEdge")
                            local topEdgeGradient = topEdge and topEdge:FindFirstChildOfClass("UIGradient")
                            local slash = card:FindFirstChild("Slash")
                            local distanceChip = card:FindFirstChild("DistanceChip")
                            local distanceChipStroke = distanceChip and distanceChip:FindFirstChild("DistanceChipStroke")
                            local pulse = getElectricPulse(model)

                            if accent then
                                accent.BackgroundColor3 = targetColor
                            end

                            if cardStroke then
                                cardStroke.Color = targetColor
                                cardStroke.Transparency = pulse.cardStrokeTransparency
                            end

                            if glow then
                                glow.BackgroundColor3 = targetColor
                                glow.BackgroundTransparency = pulse.glowTransparency
                            end

                            if topEdge then
                                topEdge.BackgroundColor3 = targetColor
                            end

                            if topEdgeGradient then
                                topEdgeGradient.Transparency = pulse.edgeTransparency
                            end

                            if slash then
                                slash.BackgroundColor3 = targetColor
                                slash.BackgroundTransparency = pulse.slashTransparency
                            end

                            if distanceChipStroke then
                                distanceChipStroke.Color = targetColor
                                distanceChipStroke.Transparency = pulse.chipStrokeTransparency
                            end

                            if nameLabel then
                                nameLabel.Visible = CONFIG.ESP_NAME
                                nameLabel.Text = CONFIG.ESP_NAME and getTargetDisplayText(model) or ""
                                nameLabel.TextColor3 = targetColor
                                nameLabel.TextSize = billboardMetrics.nameTextSize
                            end

                            if distanceLabel then
                                distanceLabel.Visible = CONFIG.ESP_DISTANCE
                                distanceLabel.Text = CONFIG.ESP_DISTANCE and ("RANGE // " .. string.upper(formatStudDistance(distance))) or ""
                                distanceLabel.TextColor3 = Color3.fromRGB(
                                    math.clamp(math.floor((targetColor.R * 255) + 72), 0, 255),
                                    math.clamp(math.floor((targetColor.G * 255) + 72), 0, 255),
                                    math.clamp(math.floor((targetColor.B * 255) + 72), 0, 255)
                                )
                                distanceLabel.TextSize = billboardMetrics.distanceTextSize
                            end

                            billboard.Enabled = CONFIG.ESP_NAME or CONFIG.ESP_DISTANCE
                        end
                    end
                end
            end
        end
    else
        clearEspOnTargets()
    end

    for model, data in pairs(ESP_CACHE) do
        if not isValidTarget(model) then
            if data.highlight then data.highlight:Destroy() end
            if data.billboard then data.billboard:Destroy() end
            ESP_CACHE[model] = nil
            VISIBILITY_CACHE[model] = nil
        end
    end
end
